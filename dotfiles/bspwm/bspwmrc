#!/usr/bin/env bash

# LightDM's X session doesn't source ~/.profile, so home-manager's
# ~/.nix-profile/bin isn't on PATH by default. Without this, sxhkd /
# polybar / picom / dunst silently fail and the screen stays black.
export PATH="$HOME/.nix-profile/bin:/run/current-system/sw/bin:/run/wrappers/bin:$PATH"

run() {
    pgrep -fx "$*" >/dev/null || "$@" &
}

bspc monitor -d I II III IV V VI VII VIII IX X

bspc config border_width         2
bspc config window_gap           8
bspc config split_ratio          0.50
bspc config borderless_monocle   true
bspc config gapless_monocle      true
bspc config focus_follows_pointer true

bspc config normal_border_color  "#3b4252"
bspc config focused_border_color "#88c0d0"
bspc config presel_feedback_color "#5e81ac"

bspc rule -a Brave-browser desktop='^2'
bspc rule -a code-oss      desktop='^3'

run sxhkd
run picom -b --config "$HOME/.config/picom/picom.conf"
run dunst
run vmware-user-suid-wrapper
run "$HOME/.config/bspwm/vmware-autofit"
"$HOME/.config/polybar/launch.sh"
