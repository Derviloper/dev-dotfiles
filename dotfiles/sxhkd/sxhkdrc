# terminal
super + Return
    ghostty

# browser
super + b
    brave

# launcher
super + space
    rofi -show drun

# window switcher
super + Tab
    rofi -show window

# reload sxhkd
super + Escape
    pkill -USR1 -x sxhkd

# restart bspwm
super + shift + r
    bspc wm -r

# quit bspwm session
super + shift + q
    bspc quit

# close / kill window
super + {_,shift + }q
    bspc node -{c,k}

# toggle tiled / monocle layout
super + m
    bspc desktop -l next

# focus / swap window in given direction
super + {_,shift + }{h,j,k,l}
    bspc node -{f,s} {west,south,north,east}

# focus desktop
super + {1-9,0}
    bspc desktop -f '^{1-9,10}'

# send focused window to desktop
super + shift + {1-9,0}
    bspc node -d '^{1-9,10}'

# toggle floating / fullscreen
super + {t,f}
    bspc node -t {tiled,fullscreen}

# expand / shrink the focused tile
super + alt + {h,j,k,l}
    bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}
