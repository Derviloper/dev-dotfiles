#!/usr/bin/env bash
# Workaround for open-vm-tools 13 + xorg modesetting on bspwm: vmware-user
# adds the host's window size as a new preferred xrandr mode but never calls
# XRRSetCrtcConfig to switch to it. Poll xrandr and apply the preferred mode
# whenever it diverges from the current one.

set -u
output="${VMWARE_AUTOFIT_OUTPUT:-Virtual-1}"

while sleep 1; do
    info=$(xrandr --query 2>/dev/null) || continue
    current=$(awk -v o="$output" '
        $1 == o && $2 == "connected" {
            for (i = 3; i <= NF; i++)
                if ($i ~ /^[0-9]+x[0-9]+\+[0-9]+\+[0-9]+/) {
                    sub(/\+.*/, "", $i); print $i; exit
                }
        }' <<<"$info")
    preferred=$(awk -v o="$output" '
        $1 == o && $2 == "connected" { in_o = 1; next }
        in_o && /^[^[:space:]]/ { in_o = 0 }
        in_o && /\+/ { print $1; exit }
    ' <<<"$info")
    if [[ -n $preferred && -n $current && $preferred != $current ]]; then
        xrandr --output "$output" --mode "$preferred"
    fi
done
